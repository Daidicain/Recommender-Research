import time
import pandas as pd
from sklearn.model_selection import train_test_split 
import numpy as np
import networkx as nx
import math

def readData(path: str, column_names: list, random_state: int, delimiter: str, skiprows: int):
    '''
    Purpose: reads data from csv file and returns the data
    Parameters: the path to the file, columns in the file
    Return: a dataframe representing data
    '''
    # read data file
    df = pd.read_csv(path, delimiter=delimiter, encoding="utf-8", names=column_names, skiprows=skiprows)
    print("total rows: ", len(df))
    # print(df)

    # item nodes need unique ids. add u/i to users/items
    df['user_id'] = 'u' + df['user_id'].astype(str)
    df['item_id'] = 'i' + df['item_id'].astype(str)
    df['rating'] = df['rating'].astype(int)
    if type(df['ts'][0]) == str:
        df['ts'] = pd.to_datetime( df['ts'].astype(str), yearfirst=True )
        df['ts'] = df['ts'].astype('int64') // 10**9
        print(df)
    
    else: df['ts'] = df['ts'].astype(int)
    # 

    min_ts = df['ts'].max() - 157_784_760 # 5 years
    # min_ts = df['ts'].max() - 31,556,926
    df = df[df['ts'] >= min_ts]
    print("1 year of rows: ",len(df))

    # filter to specific ratings
    # df = df[ df['rating'].isin([3,4,5]) ]

    # split the data into two sets train and test
    train, test = train_test_split(df, test_size=0.2, random_state=random_state)

    # split train into test sets train and validation
    train, validation = train_test_split(train, test_size=0.25, random_state=random_state)

    # all unique users and items for train set
    unique_users = df['user_id'].unique()
    unique_items = df['item_id'].unique()

    return unique_users, unique_items, test, train, validation

def createBipartiteGraph( unique_users: np.array, unique_items: np.array) -> nx.Graph:
    '''
    Purpose: This initializes the graph with users
    Parameters: Two np.arrays unique_users and unique_items.
    Return: a fully initiallized nx.graph
    '''
    # create graph object
    G = nx.Graph()

    # add user nodes
    G.add_nodes_from( unique_users, bipartite=0)

    # add item nodes.
    G.add_nodes_from( unique_items, bipartite=1)    
    
    return G

def addTimeWeightEdges(G, train, A, B1, B2):
    '''
    Purpose: This initializes the graph with users
    Parameters: Two np.arrays unique_users and unique_items.
    Return: a fully initiallized nx.graph
    '''
    # This allows for conversion from seconds to days
    secondsPerDay = 86400
    train['days'] = train['ts'].apply( lambda t: t/secondsPerDay)
    train['datetime'] = pd.to_datetime(train['ts'], unit='s', origin='unix')
    train['years'] = train['datetime'].dt.year

    # This is the most recent day. Starting from this day allows for accurate comparison
    mostRecentDay = train['days'].max()

    short_temporal_function = lambda t: (1-A) * (math.e ** -(B1 * (mostRecentDay - t)))
    long_temporal_function = lambda t: A * (1 - (math.e ** -(B2 * (mostRecentDay - t))))

    # This calculates the edges weight using the formula 1/e^tB
    train['t_weight'] = train['days'].apply( lambda t: short_temporal_function(t) + long_temporal_function(t) )

    # apply the rating to the weight
    train['t_weight'] = train.apply( lambda row: (row['rating'] * row['t_weight']), axis=1 )

    # add connections between users and items
    timeWeightedEdges = list(zip(train.user_id, train.item_id, train.t_weight))
    timeStampEdges = list(zip(train.user_id, train.item_id, train.days))
    yearsEdges = list(zip(train.user_id, train.item_id, train.years))
    ratings = list(zip(train.user_id, train.item_id, train.rating))

    G.add_weighted_edges_from(timeWeightedEdges)
    G.add_weighted_edges_from(timeStampEdges, 'ts')
    G.add_weighted_edges_from(yearsEdges, 'years')
    G.add_weighted_edges_from(ratings, 'rating')

    return train['years'].max()


def timeit(func):
    def wrapper(*args, **kwargs):
        start_time = time.time()
        result = func(*args, **kwargs)
        end_time = time.time()
        print(f"Execution time of {func.__name__}: {end_time - start_time:.4f} seconds")
        return result
    return wrapper

def extractTuple( listOfTuples: list, i: int = 1 ) -> list:
    '''
    Purpose: When given a list of tuples this returns the ith item in each tuple
    Parameters: list of tuples, and index to return
    Return: a list of one item from each tuple
    '''
    # list of tuples is empty
    if len(listOfTuples) == 0: return []

    # return second items from list of tuples
    return list( zip(*listOfTuples) )[i]


def precisionAtK(recommended: set, predict: set):
    '''
    Purpose: This tests two sets for how well they match with emphasis on accuracy with weight put on how many items are recommended
    Confusion Matrix Representation: tp/(tp+fp)
    Parameters: two sets to compare
    Return: The percent error in decimal form
    Sources:
        https://www.evidentlyai.com/ranking-metrics/precision-recall-at-k#recall-example 
        https://scikit-learn.org/stable/auto_examples/model_selection/plot_precision_recall.html
    '''
    if len(recommended) == 0: return 0
    
    # This gets True Positive
    intersection = recommended.intersection( predict )

    return len(intersection) / len(recommended)

def recallAtK(recommended, predict):
    '''
    Purpose: This tests two sets for how well they match with emphasis on accuracy regardless of how many items are recommended
    Confusion Matrix Representation: tp/(tp+fn)
    Parameters: two sets to compare
    Return: The percent error in decimal form
    Sources:
        https://www.evidentlyai.com/ranking-metrics/precision-recall-at-k#recall-example 
        https://scikit-learn.org/stable/auto_examples/model_selection/plot_precision_recall.html
        https://krishnapullak.medium.com/understanding-precision-recall-and-f-score-at-k-in-recommender-systems-7146a0dce68e
    '''
    
    # This gets True Positive
    intersection = recommended.intersection( predict )

    return len(intersection) / len(predict)

def meanAveragePrecision(recommended: set, predict: set):
    '''
    Purpose: This tests two sets for how well they match with emphasis on the first items.
    Parameters: two sets to compare
    Return: The percent error in decimal form
    Sources:
        https://www.evidentlyai.com/ranking-metrics/mean-average-precision-map
    '''
    # This gets common items between two sets
    intersection = recommended.intersection( predict )
    
    # Intersection is empty so there are no matches
    if (intersection == set()): return 0

    # sum of precision up to a given step
    precision = 0 

    # This keeps track of all relevant items up to a given step
    relevantItems = 0 

    for index, item in enumerate(recommended, 1):

        # only sum at relevant locations
        if item in intersection:

            # precision requires all relevant items up to a given step
            relevantItems += 1 

            # current relevant items divided by step
            precision += relevantItems / index 
    
    # divide precision by number of relevant items
    return precision / len(intersection)

